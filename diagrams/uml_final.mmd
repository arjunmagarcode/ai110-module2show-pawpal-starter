classDiagram
    class Task {
        +string description
        +int time_minutes
        +string scheduled_time
        +date due_date
        +string frequency
        +bool completed
        +string priority
        +string category
        +string pet_name
        +string title
        +int duration_minutes
        +bool recurring
        +next_occurrence_date()
        +create_follow_up_instance()
        +mark_complete()
        +mark_incomplete()
        +toggle_complete()
        +get_summary()
        +is_high_priority()
    }

    class Pet {
        +string name
        +string species
        +string breed
        +string care_notes
        +list tasks
        +add_task(task)
        +remove_task(task)
        +get_tasks()
        +get_pending_tasks()
        +update_profile(name, species, breed, care_notes)
        +get_care_needs()
    }

    class Owner {
        +string name
        +int available_minutes
        +string preferences
        +list pets
        +add_pet(pet)
        +remove_pet(pet_name)
        +get_pet(pet_name)
        +get_all_tasks()
        +get_pending_tasks()
        +update_preferences(preferences)
        +set_availability(available_minutes)
    }

    class Scheduler {
        +Owner owner
        +Pet pet
        +list tasks
        +collect_tasks()
        +sort_by_time(tasks)
        +sort_tasks()
        +filter_tasks(pet_name, completed, as_of, tasks)
        +generate_schedule(as_of)
        +explain_choice(as_of)
        +mark_task_complete(task)
        +get_tasks_by_pet(pet_name)
        +get_tasks_by_status(completed)
        +detect_conflicts(tasks)
    }

    Owner "1" o-- "0..*" Pet : owns
    Pet "1" *-- "0..*" Task : contains
    Scheduler "1" --> "1" Owner : uses
    Scheduler "0..1" --> "0..1" Pet : optional context
    Scheduler --> "0..*" Task : sorts/filters
